<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{orgName}}</title>
  <meta name="description" content="{{missionStatement}}" />
  <link rel="stylesheet" href="styles.css" />
  <style>
    :root {
      --primary:   {{primaryColor}};
      --secondary: {{secondaryColor}};
    }
  </style>
</head>
<body>

  <!-- ======= Navigation ======= -->
  <nav class="nav" aria-label="Main navigation">
    <div class="container nav__inner">
      <a href="#" class="nav__logo" aria-label="{{orgName}} home">
        {{#if logoUrl}}
          <img src="{{logoUrl}}" alt="{{logoAlt}}" />
        {{/if}}
        {{orgName}}
      </a>

      <ul class="nav__links" role="list">
        <li><a href="#about">About</a></li>
        <li><a href="#programs">Programs</a></li>
        {{#if impactStats}}<li><a href="#impact">Impact</a></li>{{/if}}
        {{#if volunteerText}}<li><a href="#volunteer">Volunteer</a></li>{{/if}}
        <li><a href="#contact">Contact</a></li>
      </ul>

      {{#if donationUrl}}
        <a href="{{donationUrl}}" class="btn btn-primary nav__cta" target="_blank" rel="noopener noreferrer">
          {{#if donationCta}}{{donationCta}}{{else}}Donate Now{{/if}}
        </a>
      {{/if}}
    </div>
  </nav>

  <!-- ======= Hero ======= -->
  <header class="hero" role="banner">
    <div class="container">
      <p class="hero__eyebrow">Nonprofit Organization</p>
      <h1 class="hero__title">{{orgName}}</h1>
      <p class="hero__tagline">{{tagline}}</p>
      <div class="hero__actions">
        {{#if donationUrl}}
          <a href="{{donationUrl}}" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
            {{#if donationCta}}{{donationCta}}{{else}}Donate Now{{/if}}
          </a>
        {{/if}}
        <a href="#about" class="btn btn-outline">Learn More</a>
      </div>
    </div>
  </header>

  <!-- ======= Mission ======= -->
  <section class="mission" aria-labelledby="mission-heading">
    <div class="container">
      <p class="mission__label">Our Mission</p>
      <h2 class="mission__heading" id="mission-heading">Why We Exist</h2>
      <p class="mission__text">{{missionStatement}}</p>
    </div>
  </section>

  <!-- ======= About ======= -->
  <section id="about" class="about" aria-labelledby="about-heading">
    <div class="container">
      <div class="about__grid">
        <div class="about__content">
          <p class="about__label">About Us</p>
          <h2 class="about__heading" id="about-heading">Who We Are</h2>
          <p class="about__text">{{aboutText}}</p>
        </div>
        {{#if aboutImageUrl}}
          <img src="{{aboutImageUrl}}" alt="About {{orgName}}" class="about__image" />
        {{else}}
          <div class="about__visual" aria-hidden="true">&#9829;</div>
        {{/if}}
      </div>
    </div>
  </section>

  <!-- ======= Programs ======= -->
  <section id="programs" class="programs" aria-labelledby="programs-heading">
    <div class="container">
      <h2 class="programs__heading" id="programs-heading">Our Programs</h2>
      <p class="programs__subtext">Explore the ways we serve our community.</p>
      <ul class="programs__grid" role="list">
        {{#each programs}}
          <li class="program-card">
            {{#if icon}}
              <div class="program-card__icon" aria-hidden="true">{{icon}}</div>
            {{/if}}
            <h3 class="program-card__name">{{name}}</h3>
            <p class="program-card__desc">{{description}}</p>
          </li>
        {{/each}}
      </ul>
    </div>
  </section>

  <!-- ======= Impact (optional) ======= -->
  {{#if impactStats}}
  <section id="impact" class="impact" aria-labelledby="impact-heading">
    <div class="container">
      <h2 class="impact__heading" id="impact-heading">Our Impact</h2>
      <ul class="impact__grid" role="list">
        {{#each impactStats}}
          <li>
            <p class="impact-stat__number">{{number}}</p>
            <p class="impact-stat__label">{{label}}</p>
          </li>
        {{/each}}
      </ul>
    </div>
  </section>
  {{/if}}

  <!-- ======= Donate ======= -->
  {{#if donationUrl}}
  <section class="donate" aria-labelledby="donate-heading">
    <div class="container">
      <h2 class="donate__heading" id="donate-heading">Support Our Work</h2>
      <p class="donate__text">
        Every contribution helps us further our mission and serve more people in need.
        Your generosity makes a real difference.
      </p>
      <a href="{{donationUrl}}" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
        {{#if donationCta}}{{donationCta}}{{else}}Donate Now{{/if}}
      </a>
    </div>
  </section>
  {{/if}}

  <!-- ======= Volunteer (optional) ======= -->
  {{#if volunteerText}}
  <section id="volunteer" class="volunteer" aria-labelledby="volunteer-heading">
    <div class="container">
      <h2 class="volunteer__heading" id="volunteer-heading">Volunteer With Us</h2>
      <p class="volunteer__text">{{volunteerText}}</p>
      {{#if volunteerUrl}}
        <a href="{{volunteerUrl}}" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
          Sign Up to Volunteer
        </a>
      {{/if}}
    </div>
  </section>
  {{/if}}

  <!-- ======= Contact ======= -->
  <section id="contact" class="contact" aria-labelledby="contact-heading">
    <div class="container">
      <h2 class="contact__heading" id="contact-heading">Get In Touch</h2>
      <ul class="contact__list">
        <li>
          <a href="mailto:{{email}}">{{email}}</a>
        </li>
        {{#if phone}}
          <li>
            <a href="tel:{{phone}}">{{phone}}</a>
          </li>
        {{/if}}
        {{#if address}}
          <li>{{address}}</li>
        {{/if}}
      </ul>
    </div>
  </section>

  <!-- ======= Footer ======= -->
  <footer class="footer" role="contentinfo">
    <div class="container">
      <p>
        &copy; {{year}} {{orgName}}
        <span class="footer__divider">&middot;</span>
        Built with <a href="https://ziply.app" target="_blank" rel="noopener noreferrer">Ziply</a>
      </p>
    </div>
  </footer>

</body>
</html>
